# ─── AutoTube Environment Variables ───
# Copy this file to .env and fill in your actual values

# ─── Database ───
DATABASE_URL=postgresql://autotube:autotube@db:5432/autotube
POSTGRES_USER=autotube
POSTGRES_PASSWORD=autotube
POSTGRES_DB=autotube

# ─── Redis (Celery broker) ───
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── AI API Keys ───
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ─── Visual Generation ───
GEMINIGEN_API_KEY=your_geminigen_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here

# ─── Auth ───
SECRET_KEY=your_secret_key_here

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
